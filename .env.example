# Variables de entorno — copia este archivo como .env y rellena los valores

# Django
SECRET_KEY=tu-clave-secreta-muy-larga-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (dejar vacío usa SQLite local)
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db
# DB_SSL=False

# Firebase Storage (para imágenes de productos)
# Obtener en: Firebase Console → Configuración del proyecto → Cuentas de servicio → Generar nueva clave privada
FIREBASE_STORAGE_BUCKET=tiendajoda-c73c4.firebasestorage.app
# En desarrollo: coloca el archivo JSON en la raíz del proyecto como firebase-service-account.json
# En producción (Render): pega el contenido JSON completo en esta variable:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
