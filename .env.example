# Variables de entorno — copia este archivo como .env y rellena los valores

# Django
SECRET_KEY=tu-clave-secreta-muy-larga-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (dejar vacío usa SQLite local)
# Obtén tu URL gratis en https://supabase.com → Settings → Database → Connection String
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db
# DB_SSL=True

# Firebase Storage (para imágenes de productos)
FIREBASE_STORAGE_BUCKET=tiendajoda-c73c4.firebasestorage.app
# En desarrollo: coloca el JSON en la raíz como firebase-service-account.json
# En producción (Cloud Run): pega el contenido JSON completo aquí:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Cloud Run (se configura automáticamente al desplegar)
# CLOUDRUN_SERVICE_URL=https://libreria-joda-xxxx-uc.a.run.app

